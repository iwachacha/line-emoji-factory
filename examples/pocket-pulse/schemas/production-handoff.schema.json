{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://line-emoji-factory.local/schemas/production-handoff.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release", "handoff"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "release": { "type": "string", "pattern": "^release-\\d{3}$" },
    "handoff": {
      "type": "object",
      "required": ["keep", "trim", "drift", "slot_fixes"],
      "properties": {
        "keep": { "type": "array", "items": { "type": "string" } },
        "trim": { "type": "array", "items": { "type": "string" } },
        "drift": { "type": "array", "items": { "type": "string" } },
        "series_differentiation": { "type": "array", "items": { "type": "string" } },
        "candidate_policy": {
          "type": "object",
          "properties": {
            "minimum_candidates_per_item": { "type": "integer", "minimum": 4 },
            "requires_candidate_comparison": { "type": "boolean" }
          }
        },
        "slot_fixes": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
