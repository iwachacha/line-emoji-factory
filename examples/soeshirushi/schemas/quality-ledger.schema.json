{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://line-emoji-factory.local/schemas/quality-ledger.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "open_issues", "monitoring", "closed_issues"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "open_issues": { "type": "array", "items": { "type": "object" } },
    "monitoring": { "type": "array", "items": { "type": "object" } },
    "closed_issues": { "type": "array", "items": { "type": "object" } }
  }
}
