{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://line-emoji-factory.local/schemas/submission-metadata.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "locale", "creator_name", "title", "description", "copyright"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "locale": { "type": "string", "minLength": 2 },
    "creator_name": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "copyright": { "type": "string", "minLength": 1 },
    "suggest_tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
