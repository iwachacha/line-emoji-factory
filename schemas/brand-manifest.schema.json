{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://line-emoji-factory.local/schemas/brand-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "factory_base_version",
    "template_schema_version",
    "brand",
    "product",
    "market",
    "production",
    "production_profile",
    "quality",
    "submission",
    "strategy",
    "snapshots",
    "source",
    "releases"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "factory_base_version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "template_schema_version": {
      "type": "string"
    },
    "brand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "name",
        "type",
        "stage",
        "owner"
      ],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "generic",
            "fixed_ip",
            "collaboration"
          ]
        },
        "stage": {
          "type": "string",
          "enum": [
            "idea",
            "revise",
            "design-ready",
            "production",
            "submitted",
            "released",
            "retired"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_type",
        "package_type",
        "initial_set_count",
        "animation"
      ],
      "properties": {
        "item_type": {
          "type": "string",
          "enum": [
            "static-emoji",
            "animation-emoji"
          ]
        },
        "package_type": {
          "type": "string",
          "const": "emoji"
        },
        "initial_set_count": {
          "type": "integer",
          "enum": [
            8,
            16,
            24,
            32,
            40
          ]
        },
        "animation": {
          "type": "boolean"
        }
      }
    },
    "market": {
      "$ref": "#/$defs/market"
    },
    "production": {
      "$ref": "#/$defs/production"
    },
    "production_profile": {
      "$ref": "#/$defs/production_profile"
    },
    "quality": {
      "$ref": "#/$defs/quality"
    },
    "submission": {
      "$ref": "#/$defs/submission"
    },
    "strategy": {
      "$ref": "#/$defs/strategy"
    },
    "snapshots": {
      "$ref": "#/$defs/snapshots"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "ip": {
      "$ref": "#/$defs/ip"
    },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/release"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "brand"
        ],
        "properties": {
          "brand": {
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "const": "fixed_ip"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "ip"
        ]
      }
    }
  ],
  "$defs": {
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation_log",
        "category_gap_map"
      ],
      "properties": {
        "observation_log": {
          "type": "string"
        },
        "category_gap_map": {
          "type": "string"
        }
      }
    },
    "production": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "release_root",
        "active_release",
        "final_asset_dir",
        "prompt_bundle_dir"
      ],
      "properties": {
        "profile": {
          "type": "string"
        },
        "release_root": {
          "type": "string"
        },
        "active_release": {
          "type": "string",
          "pattern": "^release-\\d{3}$"
        },
        "final_asset_dir": {
          "type": "string"
        },
        "prompt_bundle_dir": {
          "type": "string"
        }
      }
    },
    "production_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "rough_stage",
        "finalization_stage",
        "revision_stage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "rough_stage": {
          "$ref": "#/$defs/production_profile_stage"
        },
        "finalization_stage": {
          "$ref": "#/$defs/production_profile_stage"
        },
        "revision_stage": {
          "$ref": "#/$defs/production_profile_stage"
        }
      }
    },
    "production_profile_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "purpose",
        "required_outputs"
      ],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_checklist_path",
        "quality_ledger_path",
        "usage_validation_path",
        "retrospective_path",
        "release_log_path"
      ],
      "properties": {
        "release_checklist_path": {
          "type": "string"
        },
        "quality_ledger_path": {
          "type": "string"
        },
        "usage_validation_path": {
          "type": "string"
        },
        "retrospective_path": {
          "type": "string"
        },
        "release_log_path": {
          "type": "string"
        }
      }
    },
    "submission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata_path",
        "checklist_path",
        "audit_report_path"
      ],
      "properties": {
        "metadata_path": {
          "type": "string"
        },
        "checklist_path": {
          "type": "string"
        },
        "audit_report_path": {
          "type": "string"
        },
        "line_upload_dir": {
          "type": "string"
        },
        "internal_archive_dir": {
          "type": "string"
        }
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "split_reason",
        "release_policy",
        "sync_policy",
        "premium_horizon"
      ],
      "properties": {
        "split_reason": {
          "type": "string"
        },
        "release_policy": {
          "type": "string",
          "enum": [
            "manual",
            "automated",
            "unknown"
          ]
        },
        "sync_policy": {
          "type": "string",
          "enum": [
            "snapshot",
            "manual-sync",
            "unknown"
          ]
        },
        "premium_horizon": {
          "type": "string"
        }
      }
    },
    "snapshots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line_platform_baseline",
        "structure_constraints",
        "emoji_product_rules",
        "review_risk_rules",
        "evaluation_model",
        "quality_control_workflow",
        "usage_validation_workflow",
        "asset_validation_rules",
        "production_profile_rules",
        "submission_metadata_rules"
      ],
      "properties": {
        "line_platform_baseline": {
          "type": "string"
        },
        "structure_constraints": {
          "type": "string"
        },
        "emoji_product_rules": {
          "type": "string"
        },
        "review_risk_rules": {
          "type": "string"
        },
        "evaluation_model": {
          "type": "string"
        },
        "quality_control_workflow": {
          "type": "string"
        },
        "usage_validation_workflow": {
          "type": "string"
        },
        "asset_validation_rules": {
          "type": "string"
        },
        "production_profile_rules": {
          "type": "string"
        },
        "submission_metadata_rules": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "factory_repo",
        "brand_setting_path",
        "brand_positioning_path",
        "production_brief_path",
        "system_prompt_path",
        "active_release_spec_path"
      ],
      "properties": {
        "factory_repo": {
          "type": "string"
        },
        "brand_setting_path": {
          "type": "string"
        },
        "brand_positioning_path": {
          "type": "string"
        },
        "production_brief_path": {
          "type": "string"
        },
        "system_prompt_path": {
          "type": "string"
        },
        "active_release_spec_path": {
          "type": "string"
        }
      }
    },
    "ip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style_bible",
        "reference_asset_register",
        "approval_log",
        "character_expression_matrix"
      ],
      "properties": {
        "style_bible": {
          "type": "string"
        },
        "reference_asset_register": {
          "type": "string"
        },
        "approval_log": {
          "type": "string"
        },
        "character_expression_matrix": {
          "type": "string"
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "spec",
        "handoff",
        "checklist",
        "submission"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^release-\\d{3}$"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "in-production",
            "qa",
            "submitted",
            "released",
            "retired"
          ]
        },
        "spec": {
          "type": "string"
        },
        "handoff": {
          "type": "string"
        },
        "checklist": {
          "type": "string"
        },
        "submission": {
          "type": "string"
        }
      }
    }
  }
}
